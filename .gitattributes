pixi.lock merge=binary linguist-language=YAML linguist-generated=true

# Deterministic outputs generated from the experiment registry.
configs/snapshots/presets/*.json linguist-generated=true
configs/snapshots/presets/**/*.json linguist-generated=true
artifacts/experiment_plans/*.yaml linguist-generated=true

# Frozen paper outputs generated by `pixi run analysis-figures` and paper builds.
docs/header_screenshot.png linguist-generated=true
paper/figures.sha256 linguist-generated=true
paper/generated/*.tex linguist-generated=true
paper/main.pdf linguist-generated=true
paper/img/drift_matrices/**/*.pdf linguist-generated=true
paper/pages/c_yearbook.tex linguist-generated=true
paper/pages/d_amazon.tex linguist-generated=true
paper/pages/e_arxiv.tex linguist-generated=true
paper/plots_experiments/** linguist-generated=true
paper/tables/*.tex linguist-generated=true

# Frontend data and rendered result assets generated by `pixi run analysis-site`.
website/data/*.json linguist-generated=true
website/data/**/*.json linguist-generated=true
website/img/eda/** linguist-generated=true
website/results/** linguist-generated=true

# Curated public binary assets. Generated experiment outputs are ignored instead of
# broadly LFS-tracked by extension.
paper/*.pdf filter=lfs diff=lfs merge=lfs -text
paper/*.png filter=lfs diff=lfs merge=lfs -text
website/results/**/*.gif filter=lfs diff=lfs merge=lfs -text
website/results/**/*.jpg filter=lfs diff=lfs merge=lfs -text
website/results/**/*.jpeg filter=lfs diff=lfs merge=lfs -text
website/results/**/*.mp4 filter=lfs diff=lfs merge=lfs -text
website/results/**/*.png filter=lfs diff=lfs merge=lfs -text
